<%- include('components/header') %>
<%- include('partials/toasts') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Order Management</h3>
    <a href="/seller/dashboard" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to Dashboard</a>
  </div>

  <div class="row mb-3">
    <div class="col-md-4">
      <div class="input-group">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input type="text" id="searchOrders" class="form-control" placeholder="Search by customer or product...">
      </div>
    </div>
    <div class="col-md-4">
      <select id="filterStatus" class="form-select">
        <option value="all">All Statuses</option>
        <option value="pending_measurements">Pending Measurements</option>
        <option value="confirmed">Confirmed</option>
        <option value="in_stitching">In Stitching</option>
        <option value="quality_check">Quality Check</option>
        <option value="ready">Ready</option>
        <option value="delivered">Delivered</option>
        <option value="cancelled">Cancelled</option>
      </select>
    </div>
    <div class="col-md-4">
      <select id="filterType" class="form-select">
        <option value="all">All Types</option>
        <option value="rental">Rental</option>
        <option value="custom">Custom Stitching</option>
      </select>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-header bg-white">
      <h5 class="mb-0">Orders</h5>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <%- include('partials/tableHeader', { columns: [
            { label: 'Order ID', align: 'start' },
            { label: 'Product', align: 'start' },
            { label: 'Customer', align: 'start' },
            { label: 'Type', align: 'start' },
            { label: 'Status', align: 'start' },
            { label: 'Timeline', align: 'start' },
            { label: 'Amount', align: 'end' },
            { label: 'Actions', align: 'end' }
          ] }) %>
          <tbody id="ordersTableBody">
            <% if (orders && orders.length > 0) { %>
              <% orders.forEach(order => {
                const listing = order.productId || {};
                const customer = order.renterId || {};
                const isRental = listing.businessMode === 'rental' || (listing.businessMode === 'both' && order.startDate);
                const isCustom = listing.businessMode === 'custom' || listing.businessMode === 'both';
                const orderType = isRental ? 'rental' : 'custom';
                const imgUrl = (listing.image && listing.image.url) ? listing.image.url : 'https://via.placeholder.com/40';
                const status = order.orderStatus || order.status || 'pending';
              %>
              <tr data-order-type="<%= orderType %>" data-status="<%= status %>" data-customer="<%= (customer.username || '').toLowerCase() %>" data-product="<%= (listing.itemName || '').toLowerCase() %>">
                <td><small class="text-muted">#<%= String(order._id).slice(-6).toUpperCase() %></small></td>
                <td>
                  <div class="d-flex align-items-center">
                    <img src="<%= imgUrl %>" class="rounded me-2" style="width:40px;height:40px;object-fit:cover;" alt="">
                    <div>
                      <div class="fw-semibold"><%= listing.itemName || 'Product' %></div>
                      <% if (isCustom && order.selectedFabric) { %>
                        <small class="text-muted"><%= order.selectedFabric %><% if (order.selectedSize) { %>, <%= order.selectedSize %><% } %></small>
                      <% } %>
                    </div>
                  </div>
                </td>
                <td>
                  <div><%= customer.username || 'Unknown' %></div>
                  <% if (customer.email) { %><small class="text-muted"><%= customer.email %></small><% } %>
                </td>
                <td>
                  <% if (isRental) { %><span class="badge bg-secondary">Rental</span><% } else { %><span class="badge bg-info text-dark">Custom</span><% } %>
                </td>
                <td><%- include('partials/statusBadge', { status: status }) %></td>
                <td>
                  <small class="text-muted">
                    <% if (order.startDate) { %>
                      <%= new Date(order.startDate).toLocaleDateString('en-IN') %>
                      <% if (isRental && order.endDate) { %>
                        - <%= new Date(order.endDate).toLocaleDateString('en-IN') %>
                      <% } %>
                    <% } else { %>
                      TBD
                    <% } %>
                  </small>
                </td>
                <td class="text-end fw-semibold">₹<%= Number(order.totalPrice || 0).toLocaleString('en-IN') %></td>
                <td class="text-end">
                  <% if (status !== 'cancelled' && status !== 'delivered') { %>
                    <div class="dropdown">
                      <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        Update Status
                      </button>
                      <ul class="dropdown-menu">
                        <% if (status === 'pending' || status === 'pending_measurements' || status === 'confirmed' || !status) { %>
                          <% if (status !== 'confirmed') { %>
                            <li><a class="dropdown-item" href="#" onclick="updateStatus('<%= order._id %>', 'confirmed')">Confirm Order</a></li>
                            <li><hr class="dropdown-divider"></li>
                          <% } %>
                          <li><a class="dropdown-item text-danger" href="#" onclick="updateStatus('<%= order._id %>', 'cancelled')">Cancel Order</a></li>
                        <% } else if (status === 'confirmed') { %>
                          <% if (isCustom) { %>
                            <li><a class="dropdown-item" href="#" onclick="updateStatus('<%= order._id %>', 'in_stitching')">Move to Stitching</a></li>
                          <% } else { %>
                            <li><a class="dropdown-item" href="#" onclick="updateStatus('<%= order._id %>', 'delivered')">Mark Delivered</a></li>
                          <% } %>
                          <li><hr class="dropdown-divider"></li>
                          <li><a class="dropdown-item text-danger" href="#" onclick="updateStatus('<%= order._id %>', 'cancelled')">Cancel Order</a></li>
                        <% } else if (status === 'in_stitching') { %>
                          <li><a class="dropdown-item" href="#" onclick="updateStatus('<%= order._id %>', 'quality_check')">Move to Quality Check</a></li>
                        <% } else if (status === 'quality_check') { %>
                          <li><a class="dropdown-item" href="#" onclick="updateStatus('<%= order._id %>', 'ready')">Mark Ready</a></li>
                        <% } else if (status === 'ready') { %>
                          <li><a class="dropdown-item" href="#" onclick="updateStatus('<%= order._id %>', 'delivered')">Mark Delivered</a></li>
                        <% } %>
                      </ul>
                    </div>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="8" class="text-center py-5 text-muted">
                  <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                  <h5 class="mt-3">No orders found</h5>
                  <p>Your received orders will appear here.</p>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
async function updateStatus(orderId, newStatus) {
  if (!confirm(`Are you sure you want to change status to ${newStatus.replace(/_/g, ' ')}?`)) return;

  try {
    const response = await fetch(`/api/bookings/${orderId}/status`, {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      credentials: 'same-origin',
      body: JSON.stringify({ status: newStatus })
    });

    let data;
    try {
      data = await response.json();
    } catch (e) {
      data = { message: 'Invalid response from server' };
    }

    if (response.ok) {
      alert(data.message || 'Status updated successfully');
      location.reload();
    } else {
      alert(data.message || `Error: ${response.status} ${response.statusText}`);
      console.error('Status update failed:', data);
    }
  } catch (err) {
    console.error('Error updating status:', err);
    alert('Network error: Could not update status. Please check your connection and try again.');
  }
}

// Search and filter functionality
(function() {
  const searchInput = document.getElementById('searchOrders');
  const statusFilter = document.getElementById('filterStatus');
  const typeFilter = document.getElementById('filterType');
  const rows = document.querySelectorAll('#ordersTableBody tr[data-order-type]');

  function filterRows() {
    const searchTerm = (searchInput.value || '').toLowerCase();
    const statusValue = statusFilter.value;
    const typeValue = typeFilter.value;

    rows.forEach(row => {
      const customer = row.getAttribute('data-customer') || '';
      const product = row.getAttribute('data-product') || '';
      const status = row.getAttribute('data-status') || '';
      const type = row.getAttribute('data-order-type') || '';

      const matchesSearch = !searchTerm || customer.includes(searchTerm) || product.includes(searchTerm);
      const matchesStatus = statusValue === 'all' || status === statusValue;
      const matchesType = typeValue === 'all' || type === typeValue;

      row.style.display = (matchesSearch && matchesStatus && matchesType) ? '' : 'none';
    });
  }

  searchInput.addEventListener('input', filterRows);
  statusFilter.addEventListener('change', filterRows);
  typeFilter.addEventListener('change', filterRows);
})();
</script>

<%- include('components/footer') %>
