<style>
    /* ============================= */
/* FILTER PANEL - DESKTOP */
/* ============================= */

.filter-panel {
  background: #fff;
  border-radius: 16px;
  padding: 20px;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 120px;
}

.filter-panel h6 {
  font-weight: 600;
  margin-bottom: 10px;
  font-size: 14px;
}

.filter-panel .form-control,
.filter-panel .form-select {
  border-radius: 10px;
  font-size: 14px;
}

.filter-panel button {
  border-radius: 12px;
  padding: 8px;
  font-weight: 500;
}

/* ============================= */
/* MOBILE FILTER PANEL */
/* ============================= */

.mobile-filter-overlay {
  position: fixed;
  bottom: -100%;
  left: 0;
  width: 100%;
  height: 80%;
  background: #fff;
  z-index: 1050;
  transition: 0.4s ease;
  border-top-left-radius: 20px;
  border-top-right-radius: 20px;
  box-shadow: 0 -5px 25px rgba(0, 0, 0, 0.15);
  overflow-y: auto;
  padding: 20px;
}

.mobile-filter-overlay.active {
  bottom: 0;
}

.mobile-filter-header {
  font-weight: 600;
  font-size: 16px;
  margin-bottom: 15px;
}

.filter-close {
  position: absolute;
  right: 20px;
  top: 15px;
  font-size: 18px;
  cursor: pointer;
}
</style>


<form method="GET">

  <h6>Price Range</h6>
  <input type="number" name="minPrice" class="form-control mb-2" placeholder="Min">
  <input type="number" name="maxPrice" class="form-control mb-3" placeholder="Max">

  <h6>Rating</h6>
  <select name="ratingAbove" class="form-select mb-3">
    <option value="">All</option>
    <option value="4">4+ Stars</option>
    <option value="3">3+ Stars</option>
  </select>

  <h6>Category</h6>
  <select name="category" class="form-select mb-3">
    <option value="">All</option>
    <option>Men Ethnic</option>
    <option>Women Ethnic</option>
    <option>Western Wear</option>
    <option>Kids Wear</option>
    <option>Wedding Wear</option>
    <option>Designer</option>
    <option>Accessories</option>
  </select>

  <button class="btn btn-dark w-100">Apply</button>
</form>