<form id="uploadForm" action="/listing" method="POST" enctype="multipart/form-data">

  <!-- Category -->
  <div class="mb-3">
    <label for="category" class="form-label">Category</label>
    <select id="category" name="listing[category]" class="form-select" required>
      <option value="">Select Category</option>
      <option value="Men Ethnic">Men Ethnic</option>
      <option value="Women Ethnic">Women Ethnic</option>
      <option value="Western Wear">Western Wear</option>
      <option value="Kids Wear">Kids Wear</option>
      <option value="Wedding Wear">Wedding Wear</option>
      <option value="Designer">Designer</option>
      <option value="Accessories">Accessories</option>
    </select>
  </div>

  <!-- Item Name -->
  <div class="mb-3">
    <label for="itemName" class="form-label">Item Name</label>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-tag"></i></span>
      <input type="text" id="itemName" name="listing[itemName]" class="form-control" placeholder="e.g. Sherwani, Lehenga" required>
    </div>
  </div>

  <!-- Description -->
  <div class="mb-3">
    <label for="description" class="form-label">Description</label>
    <textarea id="description" name="listing[description]" class="form-control" rows="3" placeholder="Describe the outfit" required></textarea>
  </div>

  <!-- Image Upload -->
  <div class="mb-3">
    <label class="form-label">Upload Image</label>
    <div id="dropZone" style="border: 2px dashed #6c757d; padding: 30px; text-align: center; border-radius: 10px; cursor: pointer;">
      <p class="text-muted">Drag & Drop Image Here<br>or Click to Select</p>
    </div>
    <input type="file" id="image" name="listing[image]" accept="image/*" style="display:none;">
  </div>

  <!-- Business Mode -->
  <div class="mb-3">
    <label class="form-label">Business Mode</label>
    <div class="form-check">
      <input type="radio" name="listing[businessMode]" id="bmRental" value="rental" class="form-check-input" onchange="toggleBusinessMode('rental')">
      <label class="form-check-label" for="bmRental">Rental</label>
    </div>
    <div class="form-check">
      <input type="radio" name="listing[businessMode]" id="bmCustom" value="custom" class="form-check-input" onchange="toggleBusinessMode('custom')" checked>
      <label class="form-check-label" for="bmCustom">Custom Stitching</label>
    </div>
    <div class="form-check">
      <input type="radio" name="listing[businessMode]" id="bmBoth" value="both" class="form-check-input" onchange="toggleBusinessMode('both')">
      <label class="form-check-label" for="bmBoth">Both</label>
    </div>
  </div>

  <!-- Rental section -->
  <div id="rentalSection" class="border rounded p-3 mb-3" style="display: none;">
    <h6 class="text-muted">Rental</h6>
    <div class="mb-2">
      <label class="form-label">Rental Price (₹/day)</label>
      <input type="number" name="listing[pricing][rentalPricePerDay]" class="form-control" min="0" placeholder="0">
    </div>
    <div class="mb-2">
      <label class="form-label">Security Deposit (₹)</label>
      <input type="number" name="listing[pricing][securityDeposit]" class="form-control" min="0" placeholder="0">
    </div>
<div class="mb-3">
  <label class="form-label">Size Inventory</label>

  <div class="row">
    <% ["XS","S","M","L","XL","XXL"].forEach(function(size){ %>
      <div class="col-md-4 mb-2">
        <label><%= size %> Quantity</label>
        <input 
          type="number"
          name="listing[sizeInventory][<%= size %>]"
          class="form-control"
          min="0"
          value="0"
        >
      </div>
    <% }); %>
  </div>

  <small class="text-muted">
    Enter stock per size. Leave 0 if not available.
  </small>
</div>
  </div>

  <!-- Custom section -->
  <div id="customSection" class="border rounded p-3 mb-3">
    <h6 class="text-muted">Custom Stitching</h6>
    <div class="mb-2">
      <label class="form-label">Stitching Base Price (₹)</label>
      <input type="number" name="listing[pricing][stitchingBasePrice]" class="form-control" min="0" placeholder="0">
    </div>
    <div class="mb-2">
      <label class="form-label">Delivery Time (days)</label>
      <input type="number" name="listing[stitchingDurationDays]" class="form-control" min="1" value="3">
    </div>
    <div class="mb-2">
      <label class="form-label">Fabric Options (comma separated)</label>
      <input type="text" name="listing[fabricOptions]" class="form-control" placeholder="Cotton, Silk, Linen">
    </div>
    <div class="mb-2">
      <label class="form-label">Size Options (comma separated)</label>
      <input type="text" name="listing[sizeOptions]" class="form-control" placeholder="S, M, L, XL, Custom" value="S, M, L, XL, Custom">
    </div>
    <div class="mb-2">
      <label class="form-label">Measurement Fields (e.g. Chest, Waist, Shoulder, Length — one per line, add * for required)</label>
      <textarea name="listing[measurementFieldsRaw]" class="form-control" rows="3" placeholder="Chest *&#10;Waist *&#10;Shoulder&#10;Length"></textarea>
      <small class="text-muted">Format: "FieldName" or "FieldName *" for required</small>
    </div>
  </div>

  <!-- Occasions -->
  <div class="mb-3">
    <label class="form-label">Occasions (comma separated)</label>
    <input type="text" name="listing[occasions]" class="form-control" placeholder="Wedding, Party, Festival">
  </div>

  <!-- Submit -->
  <div class="d-grid">
    <button type="submit" class="btn btn-primary btn-lg">
      <i class="bi bi-check2-circle me-2"></i>Submit Listing
    </button>
  </div>
</form>

<script>
  function toggleBusinessMode(mode) {
    var rental = document.getElementById('rentalSection');
    var custom = document.getElementById('customSection');
    if (mode === 'rental') {
      rental.style.display = 'block';
      custom.style.display = 'none';
    } else if (mode === 'custom') {
      rental.style.display = 'none';
      custom.style.display = 'block';
    } else {
      rental.style.display = 'block';
      custom.style.display = 'block';
    }
  }
  document.addEventListener('DOMContentLoaded', function() {
    var checked = document.querySelector('input[name="listing[businessMode]"]:checked');
    if (checked) toggleBusinessMode(checked.value);
  });
</script>

<script>
  var dropZone = document.getElementById("dropZone");
  var fileInput = document.getElementById("image");
  dropZone.addEventListener("click", function() { fileInput.click(); });
  dropZone.addEventListener("dragover", function(e) { e.preventDefault(); dropZone.style.background = "#f1f1f1"; });
  dropZone.addEventListener("dragleave", function() { dropZone.style.background = "transparent"; });
  dropZone.addEventListener("drop", function(e) {
    e.preventDefault();
    dropZone.style.background = "transparent";
    if (e.dataTransfer.files.length > 0) {
      fileInput.files = e.dataTransfer.files;
      dropZone.innerHTML = "<p><strong>" + e.dataTransfer.files[0].name + "</strong> selected</p>";
    }
  });
  fileInput.addEventListener("change", function() {
    if (fileInput.files.length > 0)
      dropZone.innerHTML = "<p><strong>" + fileInput.files[0].name + "</strong> selected</p>";
  });
</script>
