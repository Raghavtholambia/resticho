<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Premium Listings</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>

/* ============================= */
/* GLOBAL */
/* ============================= */

body {
  font-family: 'Poppins', sans-serif;
  background: #f8f9fa;
  overflow-x: hidden;
}

/* ============================= */
/* PRODUCT CARD */
/* ============================= */

.listing-card {
  border-radius: 18px;
  overflow: hidden;
  transition: 0.3s ease;
  background: #fff;
  height: 100%;
  border: 1px solid #eee;
  display: flex;
  flex-direction: column;
}

.listing-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 15px 30px rgba(0,0,0,0.08);
}

.listing-img {
  aspect-ratio: 1/1;
  position: relative;
  overflow: hidden;
}

.listing-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: 0.5s;
}

.listing-card:hover img {
  transform: scale(1.08);
}

.badge-mode {
  position: absolute;
  top: 12px;
  left: 12px;
  font-size: 11px;
  padding: 5px 10px;
  border-radius: 20px;
  background: #000;
  color: #fff;
}

.card-body {
  padding: 12px;
}

.place-title {
  font-size: 14px;
  font-weight: 600;
}

.price-text {
  font-size: 13px;
  color: #666;
}

.rating-text {
  font-size: 12px;
  color: #888;
}

/* ============================= */
/* FILTER PANEL DESKTOP */
/* ============================= */

.filter-panel {
  background: #fff;
  border-radius: 16px;
  padding: 20px;
  position: sticky;
  top: 110px;
  box-shadow: 0 6px 20px rgba(0,0,0,0.05);
}

/* ============================= */
/* MOBILE FILTER BUTTON */
/* ============================= */

.mobile-filter-btn {
  position: fixed;
  bottom: 80px;
  right: 20px;
  background: #000;
  color: #fff;
  border-radius: 50px;
  padding: 10px 18px;
  font-size: 14px;
  z-index: 1050;
  display: none;
}

@media (max-width: 991px) {
  .mobile-filter-btn {
    display: block;
  }
}

/* ============================= */
/* MOBILE FILTER MODAL */
/* ============================= */

.mobile-filter-overlay {
  position: fixed;
  bottom: -100%;
  left: 0;
  width: 100%;
  height: 85%;
  background: #fff;
  border-radius: 20px 20px 0 0;
  transition: 0.4s ease;
  z-index: 1060;
  padding: 20px;
  overflow-y: auto;
  box-shadow: 0 -10px 30px rgba(0,0,0,0.15);
}

.mobile-filter-overlay.active {
  bottom: 0;
}

.filter-close {
  text-align: right;
  font-size: 20px;
  cursor: pointer;
}



</style>
</head>

<body>
    <div class="bg-white border-bottom sticky-category">
  <div class="container-fluid">

    <ul class="nav category-scroll py-2">

      <% 
        const categoryList = [
          "Men Ethnic",
          "Women Ethnic",
          "Western Wear",
          "Wedding Wear",
          "Party Wear",
          "Casual Wear",
          "Designer",
          "Kids Wear",
          "Accessories"
        ];
      %>

      <% categoryList.forEach(cat => { %>
        <li class="nav-item flex-shrink-0">
          <a 
            class="nav-link fw-semibold category-link <%= query?.category === cat ? 'active-category' : '' %>"
            href="/?category=<%= encodeURIComponent(cat) %>">
            <i class="fa-solid fa-tag me-1 small"></i>
            <%= cat %>
          </a>
        </li>
      <% }) %>

    </ul>

  </div>
</div>

<div class="container-fluid mt-5 pt-4">

<!-- MODE TOGGLE -->
<div class="d-flex justify-content-center mb-3">
  <div class="btn-group">
    <a href="/?mode=rental" class="btn btn-outline-dark <%= query.mode==='rental'?'active':'' %>">Rental</a>
    <a href="/?mode=custom" class="btn btn-outline-dark <%= query.mode==='custom'?'active':'' %>">Stitching</a>
    <a href="/" class="btn btn-outline-dark <%= !query.mode?'active':'' %>">All</a>
  </div>
</div>

<div class="row">

<!-- DESKTOP FILTER -->
<div class="col-lg-3 d-none d-lg-block">
  <div class="filter-panel">
    <%- include("partials/filterPanel") %>
  </div>
</div>

<!-- PRODUCT GRID -->
<div class="col-lg-9">
  <div class="row g-4">

    <% listings.forEach(listing => { %>
    <div class="col-6 col-md-6 col-lg-4">
      <a href="/listing/<%= listing._id %>" class="text-decoration-none text-dark">
        <div class="listing-card">

          <div class="listing-img">
            <img src="<%= listing.image?.url %>" alt="">
            <div class="badge-mode">
              <%= listing.businessMode === "rental" ? "Rental" : "Stitching" %>
            </div>
          </div>

          <div class="card-body">
            <div class="place-title"><%= listing.itemName %></div>
            <div class="price-text">
              ₹<%= listing.pricing?.rentalPricePerDay || listing.pricing?.stitchingBasePrice %>
            </div>
            <div class="rating-text">
              ★ <%= listing.averageRating || "New" %>
            </div>
          </div>

        </div>
      </a>
    </div>
    <% }) %>

  </div>

  <!-- PAGINATION -->
  <nav class="mt-4">
    <ul class="pagination justify-content-center">
      <% for(let i=1;i<=totalPages;i++){ %>
      <li class="page-item <%= currentPage===i?'active':'' %>">
        <a class="page-link" href="/?page=<%=i%>"><%=i%></a>
      </li>
      <% } %>
    </ul>
  </nav>

</div>
</div>
</div>

<!-- MOBILE FILTER BUTTON -->
<button class="mobile-filter-btn" onclick="openFilter()">
  <i class="fa fa-sliders"></i> Filters
</button>

<!-- MOBILE FILTER MODAL -->
<div class="mobile-filter-overlay" id="mobileFilter">
  <div class="filter-close" onclick="closeFilter()">
    <i class="fa fa-times"></i>
  </div>
  <%- include("partials/filterPanel") %>
</div>


<script>
function openFilter(){
  document.getElementById("mobileFilter").classList.add("active");
}

function closeFilter(){
  document.getElementById("mobileFilter").classList.remove("active");
}
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>