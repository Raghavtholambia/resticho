<%- include('../partials/toasts') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Admin Dashboard</h3>
  </div>

  <div class="row mb-4">
    <%- include('../partials/statsCard', { title: 'Total Users', value: totalUsers || 0, iconClass: 'bi-people', variant: 'primary' }) %>
    <%- include('../partials/statsCard', { title: 'Total Tailors', value: totalTailors || 0, iconClass: 'bi-scissors', variant: 'info' }) %>
    <%- include('../partials/statsCard', { title: 'Platform Revenue', value: '₹' + (totalRevenue || 0).toLocaleString('en-IN'), iconClass: 'bi-currency-exchange', variant: 'success' }) %>
    <%- include('../partials/statsCard', { title: 'Commission Earned', value: '₹' + (platformCommission || 0).toLocaleString('en-IN'), iconClass: 'bi-piggy-bank', variant: 'warning' }) %>
  </div>

  <ul class="nav nav-tabs mb-3" id="adminTabs" role="tablist">
    <li class="nav-item">
      <button class="nav-link active" id="users-tab" data-bs-toggle="tab" data-bs-target="#usersTab" type="button" role="tab">Users</button>
    </li>
    <li class="nav-item">
      <button class="nav-link" id="stores-tab" data-bs-toggle="tab" data-bs-target="#storesTab" type="button" role="tab">Stores</button>
    </li>
    <li class="nav-item">
      <button class="nav-link" id="listings-tab" data-bs-toggle="tab" data-bs-target="#listingsTab" type="button" role="tab">Listings</button>
    </li>
    <li class="nav-item">
      <button class="nav-link" id="orders-tab" data-bs-toggle="tab" data-bs-target="#ordersTab" type="button" role="tab">Orders</button>
    </li>
    <li class="nav-item">
      <button class="nav-link" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pendingTab" type="button" role="tab">Pending Approval</button>
    </li>
  </ul>

  <div class="tab-content">
    <div class="tab-pane fade show active" id="usersTab" role="tabpanel">
      <div class="card shadow-sm">
        <div class="card-header"><h5 class="mb-0">Users</h5></div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
              <%- include('../partials/tableHeader', { columns: [
                { label: 'Username', align: 'start' },
                { label: 'Email', align: 'start' },
                { label: 'Role', align: 'start' },
                { label: 'Verified', align: 'start' },
                { label: 'Actions', align: 'end' }
              ] }) %>
              <tbody>
                <% const allUsers = users || []; %>
                <% if (allUsers.length) { %>
                  <% allUsers.forEach(u => { %>
                  <tr>
                    <td><%= u.username %></td>
                    <td><%= u.email %></td>
                    <td><%= u.role %></td>
                    <td>
                      <% if (u.isVerified) { %><span class="badge bg-success">Verified</span><% } else { %><span class="badge bg-secondary">Unverified</span><% } %>
                    </td>
                    <td class="text-end">
                      <% if (u.role !== 'admin') { %>
                        <form action="/admin/users/<%= u._id %>/make-admin" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-outline-primary">Make Admin</button>
                        </form>
                      <% } %>
                      <% if (u.isBlocked) { %>
                        <form action="/admin/users/<%= u._id %>/unblock" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-outline-success">Unblock</button>
                        </form>
                      <% } else if (u.role !== 'admin') { %>
                        <form action="/admin/users/<%= u._id %>/block" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-outline-danger">Block</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="5" class="text-center text-muted py-4">No users found.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="tab-pane fade" id="storesTab" role="tabpanel">
      <div class="card shadow-sm">
        <div class="card-header"><h5 class="mb-0">Stores</h5></div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
              <%- include('../partials/tableHeader', { columns: [
                { label: 'Store Name', align: 'start' },
                { label: 'Owner', align: 'start' },
                { label: 'Rating', align: 'start' },
                { label: 'Approved', align: 'start' },
                { label: 'Actions', align: 'end' }
              ] }) %>
              <tbody>
                <% const storeList = stores || []; %>
                <% if (storeList.length) { %>
                  <% storeList.forEach(s => { %>
                  <tr>
                    <td><%= s.shopName %></td>
                    <td><%= (s.owner && s.owner.username) ? s.owner.username : '' %></td>
                    <td><%= (s.rating != null && s.rating.toFixed) ? s.rating.toFixed(1) : (s.rating || 0) %></td>
                    <td>
                      <% if (s.isApproved) { %><span class="badge bg-success">Approved</span><% } else { %><span class="badge bg-warning text-dark">Pending</span><% } %>
                    </td>
                    <td class="text-end">
                      <% if (!s.isApproved) { %>
                        <form action="/admin/stores/<%= s._id %>/approve" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-outline-success">Approve</button>
                        </form>
                      <% } %>
                      <form action="/admin/stores/<%= s._id %>/remove" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                      </form>
                    </td>
                  </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="5" class="text-center text-muted py-4">No stores found.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="tab-pane fade" id="listingsTab" role="tabpanel">
      <div class="card shadow-sm">
        <div class="card-header"><h5 class="mb-0">Listings</h5></div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
              <%- include('../partials/tableHeader', { columns: [
                { label: 'Product', align: 'start' },
                { label: 'Store', align: 'start' },
                { label: 'Category', align: 'start' },
                { label: 'Verified', align: 'start' },
                { label: 'Actions', align: 'end' }
              ] }) %>
              <tbody>
                <% const listingList = listings || []; %>
                <% if (listingList.length) { %>
                  <% listingList.forEach(l => { %>
                  <tr>
                    <td><%= l.itemName %></td>
                    <td><%= (l.store && l.store.shopName) ? l.store.shopName : '' %></td>
                    <td><%= l.category %></td>
                    <td>
                      <% if (l.verifiedByAdmin) { %><span class="badge bg-success">Verified</span><% } else if (l.rejectedByAdmin) { %><span class="badge bg-danger">Rejected</span><% } else { %><span class="badge bg-warning text-dark">Pending</span><% } %>
                    </td>
                    <td class="text-end">
                      <% if (!l.verifiedByAdmin) { %>
                        <form action="/admin/listings/<%= l._id %>/approve" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-outline-success">Approve</button>
                        </form>
                      <% } %>
                      <form action="/admin/listings/<%= l._id %>/remove" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                      </form>
                    </td>
                  </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="5" class="text-center text-muted py-4">No listings found.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="tab-pane fade" id="ordersTab" role="tabpanel">
      <div class="card shadow-sm">
        <div class="card-header"><h5 class="mb-0">Orders (Rent / Stitch)</h5></div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
              <%- include('../partials/tableHeader', { columns: [
                { label: 'User (Renter)', align: 'start' },
                { label: 'Product', align: 'start' },
                { label: 'Type', align: 'start' },
                { label: 'Status', align: 'start' },
                { label: 'Amount', align: 'end' },
                { label: 'Date', align: 'start' }
              ] }) %>
              <tbody>
                <% const allBookings = bookings || []; %>
                <% if (allBookings.length) { %>
                  <% allBookings.forEach(b => {
                    const listing = b.productId || {};
                    const renter = b.renterId || {};
                    const type = (listing.businessMode === 'rental' || (listing.businessMode === 'both' && b.startDate)) ? 'Rental' : 'Custom/Stitch';
                  %>
                  <tr>
                    <td><%= renter.username || '—' %><br><small class="text-muted"><%= renter.email || '' %></small></td>
                    <td><%= listing.itemName || '—' %></td>
                    <td><span class="badge <%= type === 'Rental' ? 'bg-secondary' : 'bg-info text-dark' %>"><%= type %></span></td>
                    <td><%- include('../partials/statusBadge', { status: b.orderStatus || b.status || 'pending' }) %></td>
                    <td class="text-end">₹<%= Number(b.totalPrice || 0).toLocaleString('en-IN') %></td>
                    <td><%= b.createdAt ? new Date(b.createdAt).toLocaleDateString('en-IN') : '—' %></td>
                  </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="6" class="text-center text-muted py-4">No orders yet.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="tab-pane fade" id="pendingTab" role="tabpanel">
      <div class="card shadow-sm">
        <div class="card-header"><h5 class="mb-0">Pending Approval</h5></div>
        <div class="card-body">
          <div class="row g-3">
            <% const pending = pendingListings || []; %>
            <% if (pending.length) { %>
              <% pending.forEach(listing => { %>
              <div class="col-md-4">
                <div class="card shadow-sm">
                  <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://via.placeholder.com/200' %>" class="card-img-top" style="height:180px;object-fit:cover;" alt="">
                  <div class="card-body">
                    <h6 class="card-title"><%= listing.itemName %></h6>
                    <p class="small text-muted mb-2">Owner: <%= listing.owner && listing.owner.username ? listing.owner.username : '' %></p>
                    <form action="/admin/listings/<%= listing._id %>/approve" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-success">Approve</button>
                    </form>
                    <form action="/admin/listings/<%= listing._id %>/reject" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-danger">Reject</button>
                    </form>
                  </div>
                </div>
              </div>
              <% }) %>
            <% } else { %>
              <div class="col-12 text-center text-muted py-4">No pending listings.</div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

